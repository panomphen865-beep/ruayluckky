generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
}

model Promotion {
  id          String   @id @default(cuid())
  title       String
  description String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

enum Role {
  USER
  ADMIN
}
