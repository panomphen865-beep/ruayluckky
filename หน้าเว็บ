<!doctype html>
<html lang="th">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>ruayluckky</title>
  <meta name="description" content="ruayluckky หน้าเว็บหลักโทนดำทอง" />
  <style>
    :root{--bg:#050505;--line:rgba(255,255,255,.12);--text:#f5f5f5;--muted:#b8b8b8;--gold:#D4AF37}
    *{box-sizing:border-box} body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;color:var(--text);
    background:radial-gradient(circle at 50% -10%,rgba(212,175,55,.14),transparent 40%),var(--bg)}
    a{text-decoration:none;color:inherit}
    .top{position:sticky;top:0;background:rgba(0,0,0,.75);border-bottom:1px solid var(--line);padding:12px 16px;display:flex;justify-content:space-between;align-items:center}
    .logo{font-weight:900;letter-spacing:.5px}.logo b{color:var(--gold)}
    .wrap{max-width:980px;margin:auto;padding:14px}
    .hero{margin-top:12px;border:1px solid var(--line);border-radius:18px;padding:22px;min-height:220px;display:flex;align-items:end;
    background:linear-gradient(90deg,rgba(30,0,0,.85),rgba(0,0,0,.9),rgba(30,0,0,.85))}
    h1{margin:0 0 8px;font-size:42px;line-height:1}
    .muted{color:var(--muted)}
    .btns{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:12px}
    .btn{display:block;text-align:center;padding:13px;border-radius:12px;font-weight:800;border:1px solid #000}
    .reg{background:linear-gradient(#ffd86a,#c89d1c);color:#111}
    .login{background:linear-gradient(#e11d48,#7f1d1d);color:#fff}
    .card{margin-top:12px;border:1px solid var(--line);border-radius:14px;padding:12px;background:rgba(255,255,255,.03)}
    .games{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-top:8px}
    .game{border:1px solid var(--line);border-radius:10px;padding:8px;background:rgba(0,0,0,.25)}
    @media (min-width:900px){h1{font-size:54px}.games{grid-template-columns:repeat(4,1fr)}}
  </style>
</head>
<body>
  <header class="top">
    <div class="logo">RUAY<b>LUCKKY</b></div>
    <a href="https://t.me/your_admin" target="_blank" rel="noopener">ติดต่อแอดมิน</a>
  </header>

  <main class="wrap">
    <section class="hero">
      <div>
        <h1>RUAYLUCKKY</h1>
        <div class="muted">หน้าเว็บหลักโทนดำทอง พร้อมใช้งานทันที</div>
      </div>
    </section>

    <div class="btns">
      <a class="btn reg" href="https://example.com/register" target="_blank" rel="noopener">สมัครสมาชิก</a>
      <a class="btn login" href="https://example.com/login" target="_blank" rel="noopener">เข้าสู่ระบบ</a>
    </div>

    <section class="card">
      <b>ข่าวประกาศ</b>
      <div class="muted" style="margin-top:6px">ฝาก-ถอนอัตโนมัติ 24 ชั่วโมง • รองรับมือถือ</div>
    </section>

    <section class="card">
      <b>เกมยอดฮิต</b>
      <div class="games">
        <div class="game">Mahjong Wins</div>
        <div class="game">Mahjong Gold</div>
        <div class="game">Dragon Legend</div>
        <div class="game">Lucky Stars</div>
      </div>
    </section>
  </main>
</body>
</html>
